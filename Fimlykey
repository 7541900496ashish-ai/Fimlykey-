<!DOCTYPE html>
<html>
<head>
<title>FilmlyKey Admin</title>
</head>

<body>

<h2>Add Movie</h2>

<input id="title" placeholder="Movie Title"><br><br>
<input id="image" placeholder="Poster Image URL"><br><br>
<input id="trailer" placeholder="Trailer Link"><br><br>

<button onclick="addMovie()">Add Movie</button>

<script>

function addMovie(){

let title=document.getElementById("title").value
let image=document.getElementById("image").value
let trailer=document.getElementById("trailer").value

let movies=JSON.parse(localStorage.getItem("movies")) || []

movies.push({title,image,trailer})

localStorage.setItem("movies",JSON.stringify(movies))

alert("Movie Added")

}

</script>

</body>
