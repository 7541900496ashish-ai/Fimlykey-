<!DOCTYPE html>
<html>
<head>
<title>FilmlyKey</title>

<style>

.movie{
border:1px solid #ccc;
padding:10px;
margin:10px;
width:200px;
display:inline-block;
}

img{
width:100%;
}

</style>

</head>

<body>

<h1>FilmlyKey Movies</h1>

<div id="movies"></div>

<script>

let movies=JSON.parse(localStorage.getItem("movies")) || []

let output=""

movies.forEach(movie=>{

output+=`
<div class="movie">

<img src="${movie.image}">

<h3>${movie.title}</h3>

<a href="${movie.trailer}" target="_blank">
<button>Watch Trailer</button>
</a>

</div>
`

})

document.getElementById("movies").innerHTML=output

</script>

</body>
